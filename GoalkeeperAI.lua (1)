local Players = game:GetService("Players")

local Constants = {
	-- physics movers
	ALIGN_MAX_FORCE            = 1e6,
	ALIGN_MAX_TORQUE           = 1e7,
	HOLD_MAX_FORCE             = 2e6,
	HOLD_VELOCITY              = 200,
	DASH_MAX_FORCE             = 2e5,
	HOLD_RESPONSIVENESS        = 80,   -- stiff enough to pin the ball without jitter
	ORIENTATION_RESPONSIVENESS = 30,

	-- rush / loose-ball thresholds
	SAFE_RUSH_ENEMY_DIST      = 20,   -- nearest opponent must be this far before we chase
	LOOSE_BALL_MAX_SPEED      = 5,
	LOOSE_BALL_MAX_DIST       = 25,
	BOX_SLOW_BALL_MAX_SPEED   = 10,   -- balls under this speed get scooped instantly inside the box
	BOX_DEPTH                 = 18,
	CATCH_FUDGE               = 1.5,  -- extra leniency on catch hitbox edges

	-- positioning / prediction
	GOAL_WIDTH_BUFFER         = 2,    -- shots within this margin of the post still count as on-target
	MIN_SHOT_SPEED            = 6,    -- ignore dribbles and slow rolls
	BEHIND_NET_THRESHOLD      = -1,   -- depth below zero means ball somehow got behind the goal

	-- airborne control
	AIRBORNE_Y_OFFSET         = 0.9,  -- how much to lag Y tracking while in the air
	JUMP_GROUND_TOLERANCE     = 1.15, -- clearance before we consider the keeper grounded

	-- hold step-out: walk this many studs forward when waiting to distribute
	HOLD_STEP_OUT             = 5,

	-- punch
	PUNCH_SPEED_VARIANCE      = 0.06, -- ±6% power variation so punches aren't robotic
	PUNCH_SIDE_ZONE           = 30,   -- Z range used to normalise lateral bias
	PUNCH_SIDE_BIAS           = 0.9,  -- how strongly the clear favors the ball's side
	PUNCH_SPIN_X              = 80,
	PUNCH_SPIN_Y              = 30,

	-- lob distance bands (studs) used to pick pass power
	LOB_MIN_DIST              = 6,
	LOB_SHORT_THRESHOLD       = 25,
	LOB_MED_THRESHOLD         = 60,
	LOB_ARC_DIST_REF          = 60,   -- reference distance for arc scaling
	LOB_ARC_MIN_SCALE         = 0.7,
	LOB_ARC_MAX_SCALE         = 1.6,
	LOB_BLIND_FORWARD_DIST    = 55,   -- how far downfield to throw when no teammate is open
	LOB_BLIND_HEIGHT          = 14,
	LOB_BLIND_SPREAD          = 20,   -- random Z spread on blind throws
	LOB_FALLBACK_UPWARD_VEL   = 25,   -- straight-up toss when target is too close to arc
	LOB_COLLIDE_RESTORE_DELAY = 0.25, -- seconds before re-enabling ball collision after a throw
}


local function clamp(value: number, minVal: number, maxVal: number): number
	return math.max(minVal, math.min(maxVal, value))
end

local function randRange(minVal: number, maxVal: number): number
	return minVal + (maxVal - minVal) * math.random()
end

-- returns v.Unit, or fallback when v is effectively zero length
local function safeUnit(v: Vector3, fallback: Vector3): Vector3
	return v.Magnitude > 1e-4 and v.Unit or fallback
end

local function destroyIfExists(inst: Instance?)
	if inst and inst.Parent then
		inst:Destroy()
	end
end

-- only counts living players so dead/respawning ones don't block rushes
local function getNearestPlayerDistance(pos: Vector3): number
	local nearest = math.huge
	for _, player in ipairs(Players:GetPlayers()) do
		local character = player.Character
		local humanoid  = character and character:FindFirstChildOfClass("Humanoid")
		local rootPart  = character and character:FindFirstChild("HumanoidRootPart") :: BasePart?
		if humanoid and humanoid.Health > 0 and rootPart then
			local dist = (rootPart.Position - pos).Magnitude
			if dist < nearest then
				nearest = dist
			end
		end
	end
	return nearest
end

local function createBodyPart(
	parent: Instance,
	name: string,
	size: Vector3,
	cf: CFrame,
	color: Color3,
	canCollide: boolean,
	transparency: number?
): BasePart
	local part         = Instance.new("Part")
	part.Name          = name
	part.Size          = size
	part.CFrame        = cf
	part.Color         = color
	part.Material      = Enum.Material.SmoothPlastic
	part.TopSurface    = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.CanCollide    = canCollide
	part.Transparency  = transparency or 0
	part.Parent        = parent
	return part
end

local function createMotor6D(
	part0: BasePart,
	part1: BasePart,
	name: string,
	c0: CFrame,
	c1: CFrame
): Motor6D
	local motor  = Instance.new("Motor6D")
	motor.Name   = name
	motor.Part0  = part0
	motor.Part1  = part1
	motor.C0     = c0
	motor.C1     = c1
	motor.Parent = part0
	return motor
end

local function buildR6Goalkeeper(
	teamKey: string,
	spawnCF: CFrame,
	teamColor: Color3,
	jumpPower: number
): (Model, Humanoid, BasePart, BasePart)
	local model    = Instance.new("Model")
	model.Name     = teamKey .. "_GoalkeeperNPC"

	local skinColor  = Color3.new(1, 0.85, 0.75)
	local pantsColor = Color3.new(0.15, 0.15, 0.15)

	local rootPart = createBodyPart(model, "HumanoidRootPart", Vector3.new(2, 2, 1), spawnCF, Color3.new(1, 1, 1), false, 1)
	rootPart.CanQuery = false

	local torso    = createBodyPart(model, "Torso",     Vector3.new(2, 2, 1), spawnCF,                           teamColor,  true)
	local head     = createBodyPart(model, "Head",      Vector3.new(2, 1, 1), spawnCF * CFrame.new(0, 1.5, 0),   skinColor,  true)
	local leftArm  = createBodyPart(model, "Left Arm",  Vector3.new(1, 2, 1), spawnCF * CFrame.new(-1.5, 0, 0),  teamColor,  true)
	local rightArm = createBodyPart(model, "Right Arm", Vector3.new(1, 2, 1), spawnCF * CFrame.new(1.5, 0, 0),   teamColor,  true)
	local leftLeg  = createBodyPart(model, "Left Leg",  Vector3.new(1, 2, 1), spawnCF * CFrame.new(-0.5, -2, 0), pantsColor, true)
	local rightLeg = createBodyPart(model, "Right Leg", Vector3.new(1, 2, 1), spawnCF * CFrame.new(0.5, -2, 0),  pantsColor, true)

	local humanoid        = Instance.new("Humanoid")
	humanoid.Name         = "Humanoid"
	humanoid.RigType      = Enum.HumanoidRigType.R6
	humanoid.AutoRotate   = false
	humanoid.WalkSpeed    = 0
	humanoid.JumpPower    = jumpPower
	humanoid.Parent       = model

	createMotor6D(rootPart, torso,    "RootJoint",      CFrame.new(),            CFrame.new())
	createMotor6D(torso,    head,     "Neck",           CFrame.new(0, 1, 0),     CFrame.new(0, -0.5, 0))
	createMotor6D(torso,    leftArm,  "Left Shoulder",  CFrame.new(-1, 0.5, 0),  CFrame.new(0.5, 0.5, 0))
	createMotor6D(torso,    rightArm, "Right Shoulder", CFrame.new(1, 0.5, 0),   CFrame.new(-0.5, 0.5, 0))
	createMotor6D(torso,    leftLeg,  "Left Hip",       CFrame.new(-0.5, -1, 0), CFrame.new(0, 1, 0))
	createMotor6D(torso,    rightLeg, "Right Hip",      CFrame.new(0.5, -1, 0),  CFrame.new(0, 1, 0))

	local face     = Instance.new("Decal")
	face.Name      = "face"
	face.Texture   = "rbxasset://textures/face.png"
	face.Parent    = head

	model.PrimaryPart = rootPart
	model.Parent      = workspace
	model:PivotTo(spawnCF)

	-- server owns all NPC physics; no client should ever get authority here
	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant:SetNetworkOwner(nil)
		end
	end

	return model, humanoid, rootPart, torso
end

local GoalkeeperAI = {}
GoalkeeperAI.__index = GoalkeeperAI

function GoalkeeperAI.new(deps: Deps)
	assert(deps and deps.ball and deps.gameConfig, "GoalkeeperAI.new requires ball + gameConfig")
	assert(typeof(deps.getGKOccupied)  == "function", "GoalkeeperAI.new requires getGKOccupied(teamKey)")
	assert(typeof(deps.getTeamPlayers) == "function", "GoalkeeperAI.new requires getTeamPlayers(teamKey)")

	local self = setmetatable({}, GoalkeeperAI)
	self._ball = deps.ball
	self._game = deps.gameConfig

	-- start from defaults, then layer in any caller overrides
	self._cfg = table.clone(DEFAULT)
	if deps.aiConfig then
		for key, value in pairs(deps.aiConfig :: any) do
			(self._cfg :: any)[key] = value
		end
	end

	self._getGKOccupied  = deps.getGKOccupied
	self._getTeamPlayers = deps.getTeamPlayers
	self._setBallHeld    = deps.setBallHeld   or function() end
	self._markLastTouch  = deps.markLastTouch or function() end
	self._isBallLocked   = deps.isBallLocked  or function() return false end

	self._keepers = {} :: { [string]: Keeper? }

	self._ball:SetAttribute("HeldByGK",     false)
	self._ball:SetAttribute("HeldByGKTeam", nil)

	self:_refreshKeeper("Home")
	self:_refreshKeeper("Away")

	return self
end

function GoalkeeperAI:Destroy()
	for _, teamKey in ipairs({ "Home", "Away" }) do
		self:_destroyKeeper(teamKey)
	end
end

function GoalkeeperAI:ForceRefresh()
	self:_refreshKeeper("Home")
	self:_refreshKeeper("Away")
end

function GoalkeeperAI:_destroyKeeper(teamKey: string)
	local keeper = self._keepers[teamKey]
	if not keeper then return end

	if keeper.holding then
		self:_releaseBall(keeper)
	end

	if keeper.model and keeper.model.Parent then
		keeper.model:Destroy()
	end

	self._keepers[teamKey] = nil
end

function GoalkeeperAI:_refreshKeeper(teamKey: string)
	local humanPlayerInGoal = self._getGKOccupied(teamKey)
	local existingKeeper    = self._keepers[teamKey]

	-- human just took the GK slot, tear down the NPC
	if humanPlayerInGoal then
		if existingKeeper then
			self:_destroyKeeper(teamKey)
		end
		return
	end

	-- NPC already alive and healthy
	if existingKeeper and existingKeeper.model and existingKeeper.model.Parent then
		return
	end

	local spawnPos = self._game.Spawns[teamKey] and self._game.Spawns[teamKey].GK
	if not spawnPos then return end

	local halfLength  = self._game.FieldLength / 2
	local goalX       = (teamKey == "Home") and -halfLength or halfLength
	local forwardSign = (teamKey == "Home") and 1 or -1

	local spawnCF = CFrame.lookAt(
		Vector3.new(goalX + forwardSign * (self._cfg.neutralDepth + 1), spawnPos.Y, spawnPos.Z),
		Vector3.new(goalX + forwardSign * 40, spawnPos.Y, 0)
	)

	local teamColor: Color3 = self._game.Teams[teamKey].Color3
	local model, humanoid, rootPart, torso = buildR6Goalkeeper(teamKey, spawnCF, teamColor, self._cfg.jumpPower)

	local rootAttachment      = Instance.new("Attachment")
	rootAttachment.Name       = "GK_RootAtt"
	rootAttachment.Parent     = rootPart

	local alignPosition                 = Instance.new("AlignPosition")
	alignPosition.Name                  = "GK_AlignPosition"
	alignPosition.Mode                  = Enum.PositionAlignmentMode.OneAttachment
	alignPosition.Attachment0           = rootAttachment
	alignPosition.MaxForce              = Constants.ALIGN_MAX_FORCE
	alignPosition.MaxVelocity           = self._cfg.positioningSpeed
	alignPosition.Responsiveness        = self._cfg.positioningResponsiveness
	alignPosition.RigidityEnabled       = false
	alignPosition.ApplyAtCenterOfMass   = true
	alignPosition.Parent                = rootPart

	local alignOrientation              = Instance.new("AlignOrientation")
	alignOrientation.Name               = "GK_AlignOrientation"
	alignOrientation.Mode               = Enum.OrientationAlignmentMode.OneAttachment
	alignOrientation.Attachment0        = rootAttachment
	alignOrientation.MaxTorque          = Constants.ALIGN_MAX_TORQUE
	alignOrientation.Responsiveness     = Constants.ORIENTATION_RESPONSIVENESS
	alignOrientation.PrimaryAxisOnly    = false
	alignOrientation.Parent             = rootPart

	local keeper: Keeper = {
		teamKey  = teamKey,
		model    = model,
		humanoid = humanoid,
		rootPart = rootPart,
		torso    = torso,
		groundY  = spawnPos.Y,

		alignPosition    = alignPosition,
		alignOrientation = alignOrientation,
		rootAttachment   = rootAttachment,

		nextPredictTime = 0,
		prediction      = { valid = false, timeToImpact = 0, point = Vector3.zero, speed = 0 },

		jumpCooldownUntil = 0,
		jumpAirUntil      = 0,
		dashCooldownUntil = 0,

		holding = false,
	}

	self._keepers[teamKey] = keeper
end

-- returns goalX, forwardSign (+1 Home / -1 Away), goalCenter
function GoalkeeperAI:_goalParams(teamKey: string): (number, number, Vector3)
	local halfLength  = self._game.FieldLength / 2
	local goalX       = (teamKey == "Home") and -halfLength or halfLength
	local forwardSign = (teamKey == "Home") and 1 or -1
	return goalX, forwardSign, Vector3.new(goalX, 0, 0)
end

-- Projects ball trajectory onto the keeper's plane to estimate where a shot will arrive.
-- Uses simple kinematic equations; no bounce modelling since first contact is what matters.
function GoalkeeperAI:_updatePrediction(keeper: Keeper, _now: number)
	local ball    = self._ball
	local ballPos = ball.Position
	local ballVel = ball.AssemblyLinearVelocity
	local speed   = ballVel.Magnitude
	local gravity = workspace.Gravity

	local goalX, forwardSign = self:_goalParams(keeper.teamKey)
	local keeperPlaneX       = goalX + forwardSign * self._cfg.neutralDepth

	local invalidPrediction: Prediction = { valid = false, timeToImpact = 0, point = Vector3.zero, speed = speed }

	-- ball has no meaningful X velocity, or is already moving away from this goal
	if math.abs(ballVel.X) < 1 or (goalX - ballPos.X) * ballVel.X <= 0 then
		keeper.prediction = invalidPrediction
		return
	end

	local timeToGoalLine   = (goalX        - ballPos.X) / ballVel.X
	local timeToKeeperLine = (keeperPlaneX - ballPos.X) / ballVel.X

	if timeToGoalLine <= 0 or timeToKeeperLine <= 0 or timeToKeeperLine > self._cfg.predictHorizon then
		keeper.prediction = invalidPrediction
		return
	end

	-- kinematic projection: p(t) = p0 + v*t - 0.5*g*t^2
	local function projectAtTime(t: number): (number, number)
		return ballPos.Y + ballVel.Y * t - 0.5 * gravity * t * t,
		       ballPos.Z + ballVel.Z * t
	end

	local goalY,   goalZ   = projectAtTime(timeToGoalLine)
	local keeperY, keeperZ = projectAtTime(timeToKeeperLine)

	local shotOnTarget = math.abs(goalZ) <= (self._game.GoalWidth / 2 + Constants.GOAL_WIDTH_BUFFER)

	keeper.prediction = {
		valid        = shotOnTarget and speed > Constants.MIN_SHOT_SPEED,
		timeToImpact = timeToKeeperLine,
		point        = Vector3.new(keeperPlaneX, keeperY, keeperZ),
		speed        = speed,
	}
end

-- Calculates the keeper's ideal idle position.
-- Tracks ball laterally, steps forward when in the box, retreats if ball gets behind the net.
function GoalkeeperAI:_desiredPosition(keeper: Keeper): Vector3
	local ballPos            = self._ball.Position
	local goalX, forwardSign = self:_goalParams(keeper.teamKey)
	local goalHalfWidth      = self._game.GoalWidth / 2

	local depth    = (ballPos.X - goalX) * forwardSign
	local farAlpha = clamp(1 - (depth / self._cfg.farDistance), 0, 1)

	-- scale Z tracking: full when ball is close, quarter when far away
	local zTrack = clamp(ballPos.Z, -goalHalfWidth + self._cfg.goalSideMargin, goalHalfWidth - self._cfg.goalSideMargin)
	zTrack *= (0.25 + 0.75 * farAlpha)

	local xPos = goalX + forwardSign * self._cfg.neutralDepth

	if depth > 0 and depth <= self._cfg.penaltyDepth and math.abs(ballPos.Z) <= self._cfg.penaltyHalfWidth then
		-- step forward proportionally: fully out at the top of the box, barely at the line
		local stepAlpha = 1 - (depth / self._cfg.penaltyDepth)
		xPos = goalX + forwardSign * (self._cfg.neutralDepth + self._cfg.stepOutDepth * stepAlpha)
	end

	if depth < Constants.BEHIND_NET_THRESHOLD then
		xPos   = goalX + forwardSign * self._cfg.neutralDepth
		zTrack = 0
	end

	return Vector3.new(xPos, keeper.groundY, zTrack)
end

function GoalkeeperAI:_setKeeperTarget(keeper: Keeper, target: Vector3, stickToGround: boolean)
	local yTarget = keeper.groundY
	local now     = os.clock()
	local state   = keeper.humanoid:GetState()

	local isAirborne = state == Enum.HumanoidStateType.Jumping
		or state == Enum.HumanoidStateType.Freefall
		or state == Enum.HumanoidStateType.FallingDown

	-- while airborne, lag the Y target so the physics sim handles the drop naturally
	if not stickToGround and (isAirborne or now < keeper.jumpAirUntil) then
		yTarget = math.max(keeper.groundY, keeper.rootPart.Position.Y - Constants.AIRBORNE_Y_OFFSET)
	end

	keeper.alignPosition.Position = Vector3.new(target.X, yTarget, target.Z)
end

function GoalkeeperAI:_faceBall(keeper: Keeper)
	local keeperPos = keeper.rootPart.Position
	local ballPos   = self._ball.Position
	-- flatten to keeper Y so the torso doesn't tilt chasing a high ball
	keeper.alignOrientation.CFrame = CFrame.lookAt(keeperPos, Vector3.new(ballPos.X, keeperPos.Y, ballPos.Z))
end

function GoalkeeperAI:_clearGuidanceForBall()
	for _, child in ipairs(self._ball:GetChildren()) do
		if (child:IsA("Attachment") and child.Name == "KickAtt") or child:IsA("LinearVelocity") then
			child:Destroy()
		end
	end
end

-- OBB distance: 0 = ball is inside the save box, positive = studs outside it
function GoalkeeperAI:_ballDistToSaveBox(keeper: Keeper): number
	local ballLocal = keeper.torso.CFrame:PointToObjectSpace(self._ball.Position)
	local halfSize  = self._cfg.saveHitboxSize * 0.5
	local relative  = ballLocal - self._cfg.saveHitboxOffset

	local overX = math.max(math.abs(relative.X) - halfSize.X, 0)
	local overY = math.max(math.abs(relative.Y) - halfSize.Y, 0)
	local overZ = math.max(math.abs(relative.Z) - halfSize.Z, 0)

	return math.sqrt(overX * overX + overY * overY + overZ * overZ)
end

function GoalkeeperAI:_holdBall(keeper: Keeper)
	if keeper.holding or not self._ball.Parent then return end

	self:_clearGuidanceForBall()
	self._markLastTouch(keeper.teamKey, nil)

	self._ball.AssemblyLinearVelocity  = Vector3.zero
	self._ball.AssemblyAngularVelocity = Vector3.zero
	self._ball:SetNetworkOwner(nil)

	keeper.holding = true
	self._ball.CanCollide = false
	self._setBallHeld(true, keeper.teamKey)
	self._ball:SetAttribute("HeldByGK",     true)
	self._ball:SetAttribute("HeldByGKTeam", keeper.teamKey)

	-- torso attachment is the anchor; ball attachment follows it via AlignPosition
	local torsoAtt          = Instance.new("Attachment")
	torsoAtt.Name           = "GK_HoldTorsoAtt"
	torsoAtt.Position       = Vector3.new(0, 0.25, -1.1)
	torsoAtt.Parent         = keeper.torso
	keeper.holdTorsoAttachment = torsoAtt

	local ballAtt       = Instance.new("Attachment")
	ballAtt.Name        = "GK_HoldBallAtt"
	ballAtt.Parent      = self._ball
	keeper.holdBallAttachment = ballAtt

	local holdAlignPos              = Instance.new("AlignPosition")
	holdAlignPos.Name               = "GK_BallHoldAlignPosition"
	holdAlignPos.Attachment0        = ballAtt
	holdAlignPos.Attachment1        = torsoAtt
	holdAlignPos.MaxForce           = Constants.HOLD_MAX_FORCE
	holdAlignPos.MaxVelocity        = Constants.HOLD_VELOCITY
	holdAlignPos.Responsiveness     = Constants.HOLD_RESPONSIVENESS
	holdAlignPos.RigidityEnabled    = true
	holdAlignPos.Parent             = self._ball
	keeper.holdAlignPosition        = holdAlignPos

	local holdAlignOri              = Instance.new("AlignOrientation")
	holdAlignOri.Name               = "GK_BallHoldAlignOrientation"
	holdAlignOri.Attachment0        = ballAtt
	holdAlignOri.Attachment1        = torsoAtt
	holdAlignOri.MaxTorque          = Constants.ALIGN_MAX_TORQUE
	holdAlignOri.Responsiveness     = Constants.HOLD_RESPONSIVENESS
	holdAlignOri.RigidityEnabled    = true
	holdAlignOri.Parent             = self._ball
	keeper.holdAlignOrientation     = holdAlignOri

	keeper.throwAt = os.clock() + randRange(self._cfg.holdMin, self._cfg.holdMax)
end

function GoalkeeperAI:_releaseBall(keeper: Keeper)
	destroyIfExists(keeper.holdAlignOrientation)
	keeper.holdAlignOrientation = nil
	destroyIfExists(keeper.holdAlignPosition)
	keeper.holdAlignPosition = nil
	destroyIfExists(keeper.holdBallAttachment)
	keeper.holdBallAttachment = nil
	destroyIfExists(keeper.holdTorsoAttachment)
	keeper.holdTorsoAttachment = nil

	keeper.holding = false
	keeper.throwAt = nil

	self._ball.CanCollide = true
	self._setBallHeld(false, nil)
	self._ball:SetAttribute("HeldByGK",     false)
	self._ball:SetAttribute("HeldByGKTeam", nil)
end

function GoalkeeperAI:_findClosestTeammate(teamKey: string, fromPos: Vector3): BasePart?
	local bestRoot: BasePart? = nil
	local bestDist = math.huge

	for _, player in ipairs(self._getTeamPlayers(teamKey)) do
		local character = player.Character
		local humanoid  = character and character:FindFirstChildOfClass("Humanoid")
		local rootPart  = character and character:FindFirstChild("HumanoidRootPart") :: BasePart?
		if humanoid and humanoid.Health > 0 and rootPart then
			local dist = (rootPart.Position - fromPos).Magnitude
			if dist < bestDist then
				bestDist = dist
				bestRoot = rootPart
			end
		end
	end

	return bestRoot
end

-- Computes a ballistic lob velocity from startPos to targetPos.
-- Pass speed scales across three distance bands to avoid laser-beam short passes and
-- floaty long ones. Arc height scales the same way so near passes don't dig into the ground.
function GoalkeeperAI:_computeLobVelocity(startPos: Vector3, targetPos: Vector3): Vector3
	local gravity  = workspace.Gravity
	local delta    = targetPos - startPos
	local flatVec  = Vector3.new(delta.X, 0, delta.Z)
	local distance = flatVec.Magnitude

	if distance < Constants.LOB_MIN_DIST then
		return Vector3.new(0, Constants.LOB_FALLBACK_UPWARD_VEL, 0)
	end

	local passSpeed: number
	if distance < Constants.LOB_SHORT_THRESHOLD then
		passSpeed = self._cfg.lobMinPower
	elseif distance < Constants.LOB_MED_THRESHOLD then
		passSpeed = (self._cfg.lobMinPower + self._cfg.lobMaxPower) * 0.5
	else
		passSpeed = self._cfg.lobMaxPower
	end

	local arcScale   = clamp(distance / Constants.LOB_ARC_DIST_REF, Constants.LOB_ARC_MIN_SCALE, Constants.LOB_ARC_MAX_SCALE)
	local arcHeight  = self._cfg.lobArcHeight * arcScale
	local timeArc    = 2 * math.sqrt((2 * arcHeight) / gravity)
	local timeSpeed  = distance / passSpeed
	local travelTime = math.max(timeArc, timeSpeed)

	-- ballistic formula: v = (Δp + ½g*t²*ĵ) / t  — the Y term compensates for gravity drop
	local velocity = (delta + Vector3.new(0, 0.5 * gravity * travelTime * travelTime, 0)) / travelTime

	-- small random error in both power and direction so passes don't look scripted
	velocity *= (1 + randRange(-self._cfg.lobPowerRand, self._cfg.lobPowerRand))
	local passDir = safeUnit(flatVec, Vector3.new(1, 0, 0))
	local perpDir = Vector3.new(-passDir.Z, 0, passDir.X)
	velocity     += perpDir * (passSpeed * randRange(-self._cfg.lobDirRand, self._cfg.lobDirRand))

	return velocity
end

function GoalkeeperAI:_distributeBall(keeper: Keeper)
	if not keeper.holding or not self._ball then return end

	local teammate = self:_findClosestTeammate(keeper.teamKey, keeper.rootPart.Position)
	local targetPos: Vector3

	if teammate then
		targetPos = teammate.Position
	else
		-- no one open; punt downfield and hope for the best
		local _, forwardSign = self:_goalParams(keeper.teamKey)
		local lateralJitter  = Vector3.new(0, 0, math.random(-Constants.LOB_BLIND_SPREAD, Constants.LOB_BLIND_SPREAD))
		targetPos = keeper.rootPart.Position
			+ Vector3.new(forwardSign * Constants.LOB_BLIND_FORWARD_DIST, Constants.LOB_BLIND_HEIGHT, 0)
			+ lateralJitter
	end

	self:_releaseBall(keeper)
	self._ball.CanCollide = false

	-- defer one frame so _releaseBall's physics changes settle before applying velocity
	task.defer(function()
		if not (self._ball and self._ball.Parent) then return end
		self._ball.AssemblyLinearVelocity = self:_computeLobVelocity(self._ball.Position, targetPos)
		task.delay(Constants.LOB_COLLIDE_RESTORE_DELAY, function()
			if self._ball and self._ball.Parent then
				self._ball.CanCollide = true
			end
		end)
	end)
end

function GoalkeeperAI:_dashLaterally(keeper: Keeper, zTarget: number)
	local now = os.clock()
	if now < keeper.dashCooldownUntil then return end

	keeper.dashCooldownUntil = now + self._cfg.dashCooldown

	local dashDir = (zTarget - keeper.rootPart.Position.Z >= 0) and 1 or -1

	local dashAttachment    = Instance.new("Attachment")
	dashAttachment.Name     = "GK_DashAtt"
	dashAttachment.Parent   = keeper.rootPart

	local linearVelocity              = Instance.new("LinearVelocity")
	linearVelocity.Name               = "GK_DashLV"
	linearVelocity.Attachment0        = dashAttachment
	linearVelocity.RelativeTo         = Enum.ActuatorRelativeTo.World
	linearVelocity.MaxForce           = Constants.DASH_MAX_FORCE
	linearVelocity.VectorVelocity     = Vector3.new(0, 0, dashDir * self._cfg.dashSpeed)
	linearVelocity.Parent             = keeper.rootPart

	task.delay(self._cfg.dashDuration, function()
		destroyIfExists(linearVelocity)
		destroyIfExists(dashAttachment)
	end)
end

function GoalkeeperAI:_tryJump(keeper: Keeper)
	local now = os.clock()
	if now < keeper.jumpCooldownUntil then return end

	local isGrounded = keeper.humanoid.FloorMaterial ~= Enum.Material.Air
		and keeper.rootPart.Position.Y <= keeper.groundY + Constants.JUMP_GROUND_TOLERANCE
	if not isGrounded then return end

	keeper.jumpCooldownUntil = now + self._cfg.jumpCooldown
	keeper.jumpAirUntil      = now + self._cfg.jumpAirControlTime

	keeper.humanoid.JumpPower = self._cfg.jumpPower
	keeper.humanoid.Jump      = true
	keeper.humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

	-- clamp upward velocity in case the engine's jump didn't fire hard enough
	local currentVel = keeper.rootPart.AssemblyLinearVelocity
	if currentVel.Y < self._cfg.jumpBoostVel then
		keeper.rootPart.AssemblyLinearVelocity = Vector3.new(currentVel.X, self._cfg.jumpBoostVel, currentVel.Z)
	end
end

